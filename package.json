import mongoose from 'mongoose';

export const NOTE_COLORS = [
  'default',
  'yellow',
  'coral',
  'mint',
  'sky',
  'lavender',
  'peach',
  'rose',
  'sage',
];

const noteSchema = new mongoose.Schema(
  {
    user: { type: mongoose.Schema.Types.ObjectId, ref: 'User', required: true, index: true },
    title: { type: String, default: '', trim: true, maxlength: 200 },
    content: { type: String, default: '' }, // sanitized HTML from the editor
    plainText: { type: String, default: '' }, // for search + previews
    color: { type: String, enum: NOTE_COLORS, default: 'default' },
    notebook: { type: String, default: '', trim: true, maxlength: 60 },
    tags: [{ type: String, trim: true, maxlength: 40 }],

    pinned: { type: Boolean, default: false },
    favorite: { type: Boolean, default: false },
    archived: { type: Boolean, default: false },
    trashed: { type: Boolean, default: false },
    trashedAt: Date,

    // Sharing
    collaborators: [
      {
        user: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
        role: { type: String, enum: ['viewer', 'editor'], default: 'viewer' },
      },
    ],
    shareToken: { type: String, index: true, sparse: true },
    shareEnabled: { type: Boolean, default: false },

    reminderAt: Date,
    order: { type: Number, default: 0 },
  },
  { timestamps: true }
);

noteSchema.index({ title: 'text', plainText: 'text', tags: 'text' });
noteSchema.index({ user: 1, updatedAt: -1 });
noteSchema.index({ 'collaborators.user': 1 });

export default mongoose.model('Note', noteSchema);
